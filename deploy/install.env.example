# Скопируйте этот файл в deploy/install.env и измените четыре значения ниже.
# Пароли сюда добавлять не нужно: установщик создаст служебные пароли сам.

# IP-адрес или внутреннее DNS-имя, по которому будут открывать программу.
SERVER_NAME=

# Доверенная IPv4-сеть, из которой разрешено открывать программу.
# Примеры: 10.0.0.0/8, 192.168.1.0/24, 10.20.30.40/32.
TRUSTED_CIDR=

# Первая учётная запись руководителя.
ADMIN_USERNAME=
ADMIN_EMAIL=

# Сначала установщик разрешит SSH и только после этого включит сетевой экран.
# Укажите false, только если сетевым экраном сервера управляют отдельно.
ENABLE_UFW=true
SSH_PORT=22
