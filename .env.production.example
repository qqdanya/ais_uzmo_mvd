# Production environment template for АИС УЗМО.
# Copy this file to .env on the server and replace placeholder values.
# Do not commit the real .env file to Git.

SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=example.ru,www.example.ru
CSRF_TRUSTED_ORIGINS=https://example.ru,https://www.example.ru

# Use PostgreSQL in production. SQLite is only for local development/tests.
DATABASE_URL=postgres://uzmo_user:change-me@127.0.0.1:5432/uzmo_db

# Relative path from BASE_DIR or absolute path on the server.
MEDIA_ROOT=media

# HTTPS/security settings. Production should run behind HTTPS.
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Initial superuser for seed_initial_data.
# After the first successful seed, remove SUPERUSER_PASSWORD from the real server .env
# or replace it with a non-working value.
SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=change-me-before-deploy
