# Reference template for a separately designed production deployment of АИС УЗМО.
# The standard deploy/install.sh creates .env itself; do not copy this file over it.
# Do not commit the real server .env file to Git.

SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=example.ru,www.example.ru
CSRF_TRUSTED_ORIGINS=https://example.ru,https://www.example.ru

# Use PostgreSQL in production. SQLite is only for local development/tests.
DATABASE_URL=postgres://ais_uzmo:change-me@127.0.0.1:5432/ais_uzmo
DB_CONN_MAX_AGE=60

# Shared cache for all Gunicorn workers. Redis must be reachable only from
# trusted hosts; use redis://:password@host:6379/1 when authentication is set.
REDIS_URL=redis://:change-me@127.0.0.1:6379/1
CACHE_KEY_PREFIX=ais_uzmo
CACHE_DEFAULT_TIMEOUT=300

# Relative path from BASE_DIR or absolute path on the server.
MEDIA_ROOT=media
LOG_DIR=logs
ADMIN_THRESHOLDS_FILE=/srv/ais_uzmo/runtime/dashboard_thresholds.json

# HTTPS/security settings for a deployment whose TLS support is configured and tested.
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Initial superuser for seed_initial_data.
# After the first successful seed, remove SUPERUSER_PASSWORD from the real server .env
# or replace it with a non-working value.
SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=change-me-before-deploy
